# Auto-detect text files and normalize line endings in Git.
* text=auto

# Source, config, and docs should stay LF across Windows, WSL, and Linux hosts.
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.sh text eol=lf
*.sql text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Windows shell scripts should remain native for Windows tooling.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
