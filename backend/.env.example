# Environment
NODE_ENV=development
LOG_LEVEL=debug

# HTTP / process mode
PORT=
BACKEND_MODE=all

# Database
MONGODB_URI=
MONGODB_DB_NAME=
DATABASE_BACKUP_ENABLED=false
DATABASE_BACKUP_CRON=0 */12 * * *
DATABASE_BACKUP_TIMEZONE=Asia/Manila
DATABASE_BACKUP_DIR=backups
DATABASE_BACKUP_RETENTION_COUNT=14

# Riot API
RIOT_API_KEY=

# Admin API
ADMIN_API_PASSWORD=

# Tournament defaults
TOURNAMENT_START_DATE=2025-01-01T00:00:00Z
TOURNAMENT_END_DATE=2025-01-14T23:59:59Z

# Runtime tuning
CRON_PLAYER_CONCURRENCY=3
ENABLE_DEV_DATA_FETCH_CRONS=false
LEADERBOARD_CACHE_TTL_MS=30000
NOTIFICATION_FEED_LIMIT=50
